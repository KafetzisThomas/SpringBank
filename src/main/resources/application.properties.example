spring.application.name=SpringBank
spring.main.banner-mode=off
logging.level.root=warn
logging.level.org.springframework.security=DEBUG

spring.datasource.url=jdbc:mysql://localhost:3306/springbank
spring.datasource.username=YOUR_DB_USERNAME
spring.datasource.password=YOUR_DB_PASSWORD

# Hibernate DDL auto config
# create: drop and recreate tables each time (not for production)
# update: keep existing data, update schema
spring.jpa.hibernate.ddl-auto=update

# Enable all endpoints for actuator
management.endpoints.web.exposure.include=*

# ------------ Usefull actuator endpoints ------------
# /beans: returns all available beans in our BeanFactory
# /env: returns current environment properties
# /health: summarizes the health status of our application
# /metrics: details metrics of our application
# /loggers: enables us to query and modify the logging level of our application
# /threaddump: dumps the thread information of the underlying JVM
